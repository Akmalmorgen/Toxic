# ─────────────────────────────────────────────────────────────
#  𐌽ꤕ𐌗ተ — пример переменных окружения
#  Скопируйте этот файл в .env и заполните значения:
#      cp .env.example .env
# ─────────────────────────────────────────────────────────────

# ОБЯЗАТЕЛЬНО. Токен бота от @BotFather
BOT_TOKEN=8879690700:AAEESNjlKBfpdxEijbX6-TWF2LB-2QWXNE4

# ОБЯЗАТЕЛЬНО для админ-панели. ID администраторов через запятую.
# Свой ID можно узнать у @userinfobot
ADMIN_IDS=8420384039

# РЕКОМЕНДУЕТСЯ. Строка подключения к PostgreSQL (например, бесплатный Neon).
# Без неё бот работает на SQLite, и на эфемерных хостингах (Render free)
# все данные стираются при каждом перезапуске!
# Формат: postgresql://user:password@host/dbname?sslmode=require
DATABASE_URL=postgresql://neondb_owner:npg_ptBiQ6NAL9xy@ep-floral-frost-aspa3srd-pooler.c-4.eu-central-1.aws.neon.tech/neondb?sslmode=require&channel_binding=require

# НЕОБЯЗАТЕЛЬНО. Путь к файлу SQLite (используется, если DATABASE_URL пуст).
# По умолчанию: ./bot.db
DB_PATH=
